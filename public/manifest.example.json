{
  "manifest_version": 3,
  "name": "Chrome HUD New Tab",
  "version": "2.0",
  "description": "Una dashboard moderna in React con widget Meteo, Task, News, Shortcuts e Temi personalizzati.",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "permissions": [
    "storage",
    "unlimitedStorage",
    "geolocation",
    "identity",
    "alarms",
    "notifications"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "oauth2": {
    "client_id": "INSERISCI_QUI_IL_TUO_CLIENT_ID",
    "scopes": [
      "https://www.googleapis.com/auth/tasks"
    ]
  },
  "host_permissions": [
    "https://api.open-meteo.com/*",
    "https://air-quality-api.open-meteo.com/*",
    "https://api.rss2json.com/*",
    "https://api.fisenko.net/*",
    "https://*.google.com/*",
    "https://nominatim.openstreetmap.org/*",
    "https://tasks.googleapis.com/*",
    "https://www.ilsole24ore.com/*",
    "https://www.corrieredellosport.it/*",
    "https://cdn.corrieredellosport.it/*"
  ]
}
